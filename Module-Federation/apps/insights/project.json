{
  "name": "insights",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/insights/src",
  "tags": ["scope:insights"],
  "implicitDependencies": ["ui", "utils"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        { "projects": ["ui", "utils"], "target": "build" }
      ],
      "options": {
        "command": "rspack build --node-env production",
        "cwd": "apps/insights"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rspack serve --node-env development",
        "cwd": "apps/insights"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src --ext .ts,.tsx",
        "cwd": "apps/insights"
      }
    }
  }
}
